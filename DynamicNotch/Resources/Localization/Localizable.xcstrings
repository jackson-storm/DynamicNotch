    "Run every debug event in sequence, keep each item visible for its configured duration, wait 1 second between items, and skip onboarding, notch size, and lock screen previews." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Run every debug event in sequence, keep each item visible for its configured duration, wait 1 second between items, and skip onboarding, notch size, and lock screen previews."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ejecute cada evento de depuración en secuencia, mantenga cada elemento visible durante la duración configurada, espere 1 segundo entre elementos y omita la incorporación, el tamaño de la muesca y las vistas previas de la pantalla de bloqueo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exécutez chaque événement de débogage dans l'ordre, gardez chaque élément visible pendant sa durée configurée, attendez 1 seconde entre les éléments et ignorez l'intégration, la taille de l'encoche et les aperçus de l'écran de verrouillage."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのデバッグ イベントを順番に実行し、設定された期間中各項目を表示したままにし、項目間で 1 秒待機し、オンボーディング、ノッチ サイズ、ロック画面のプレビューをスキップします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 디버그 이벤트를 순차적으로 실행하고, 구성된 기간 동안 각 항목이 표시되도록 유지하고, 항목 사이에 1초를 기다리며, 온보딩, 노치 크기 및 잠금 화면 미리보기를 건너뜁니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Execute todos os eventos de depuração em sequência, mantenha cada item visível durante a duração configurada, aguarde 1 segundo entre os itens e pule a integração, o tamanho do entalhe e as visualizações da tela de bloqueio."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Запустить все отладочные события по очереди, держать каждый элемент видимым заданное время, ждать 1 секунду между ними и пропускать предпросмотры онбординга, изменения размера выреза и экрана блокировки."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按顺序运行每个调试事件，在配置的持续时间内保持每个项目可见，在项目之间等待 1 秒，并跳过启动、缺口大小和锁定屏幕预览。"
          }
        }
      }
    },
    "Scale the duration of temporary activities across HUD, battery, connectivity, and resize feedback." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scale the duration of temporary activities across HUD, battery, connectivity, and resize feedback."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escale la duración de las actividades temporales en HUD, batería, conectividad y retroalimentación de cambio de tamaño."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajustez la durée des activités temporaires sur le HUD, la batterie, la connectivité et redimensionnez les commentaires."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HUD、バッテリー、接続性、およびサイズ変更フィードバック全体にわたる一時的なアクティビティの継続時間を調整します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HUD, 배터리, 연결 및 크기 조정 피드백 전반에 걸쳐 임시 활동 기간을 조정합니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dimensione a duração de atividades temporárias em HUD, bateria, conectividade e feedback de redimensionamento."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Масштабировать длительность временных активностей для HUD, батареи, подключений и подсказок изменения размера."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "扩展 HUD、电池、连接等临时活动的持续时间，并调整反馈大小。"
          }
        }
      }
    },
