      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep playback controls in the notch while media is playing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenga los controles de reproducción en la muesca mientras se reproducen los medios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gardez les commandes de lecture dans l'encoche pendant la lecture du média."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メディアの再生中は、再生コントロールをノッチ内に保ちます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "미디어가 재생되는 동안 재생 컨트롤을 노치에 유지하세요."
