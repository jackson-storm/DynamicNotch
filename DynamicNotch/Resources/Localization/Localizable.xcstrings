    "Keep the app visible in the Dock for faster switching and window access." : {

    },
    "Keep the hotspot live activity visible until you turn it off." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep the hotspot live activity visible until you turn it off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenga visible la actividad en vivo del punto de acceso hasta que lo apague."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gardez l'activité en direct du point d'accès visible jusqu'à ce que vous la désactiviez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "オフにするまでホットスポットのライブ アクティビティを表示したままにします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
