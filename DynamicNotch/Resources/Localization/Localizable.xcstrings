    ", it is recommended to charge it." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ", it is recommended to charge it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ", se recomienda cargarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ", il est recommandé de le charger."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "、充電することをお勧めします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ", 충전하는 것이 좋습니다."
