    "Apply a full battery sample and show the completion notification." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apply a full battery sample and show the completion notification."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplique una muestra de batería llena y muestre la notificación de finalización."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appliquez un échantillon de batterie complet et affichez la notification d'achèvement."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "満充電のバッテリーサンプルを適用し、完了通知を表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "전체 배터리 샘플을 적용하고 완료 알림을 표시합니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplique uma amostra completa da bateria e mostre a notificação de conclusão."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Применить пример полного заряда и показать уведомление о завершении."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用完整的电池样本并显示完成通知。"
          }
        }
      }
    },
    "Apply a low battery sample and show the low-power alert." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apply a low battery sample and show the low-power alert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplique una muestra de batería baja y muestre la alerta de bajo consumo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appliquez un échantillon de batterie faible et affichez l’alerte de faible puissance."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バッテリー低下のサンプルを適用し、低電力アラートを表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "배터리 부족 샘플을 적용하고 저전력 경고를 표시합니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplique uma amostra de bateria fraca e mostre o alerta de baixa energia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Применить пример низкого заряда и показать предупреждение."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用低电量示例并显示低电量警报。"
          }
        }
      }
    },
    "Apply a sample charging state and show the charger notification." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apply a sample charging state and show the charger notification."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplique un estado de carga de muestra y muestre la notificación del cargador."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appliquez un exemple d'état de charge et affichez la notification du chargeur."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サンプルの充電状態を適用し、充電器の通知を表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "샘플 충전 상태를 적용하고 충전기 알림을 표시합니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplique um exemplo de estado de carregamento e mostre a notificação do carregador."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Применить пример состояния зарядки и показать уведомление о зарядке."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用示例充电状态并显示充电器通知。"
          }
        }
      }
    },
    "Apply the standard white stroke to supported activities instead of feature accent colors." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apply the standard white stroke to supported activities instead of feature accent colors."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplique el trazo blanco estándar a las actividades admitidas en lugar de resaltar los colores."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appliquez le trait blanc standard aux activités prises en charge au lieu des couleurs d’accentuation des fonctionnalités."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "機能のアクセントカラーの代わりに、標準の白のストロークをサポートされているアクティビティに適用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "특징 강조 색상 대신 지원되는 활동에 표준 흰색 획을 적용합니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplique o traço branco padrão às atividades suportadas em vez das cores de destaque dos recursos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Использовать стандартную белую обводку для поддерживаемых активностей вместо акцентных цветов функций."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将标准白色描边应用于支持的活动，而不是特征强调色。"
          }
        }
      }
    },
