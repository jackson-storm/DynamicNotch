    "Short-lived overlays appear above live activities so quick system events still feel prominent." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Short-lived overlays appear above live activities so quick system events still feel prominent."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aparecen superposiciones de corta duración encima de las actividades en vivo, por lo que los eventos rápidos del sistema aún se destacan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des superpositions de courte durée apparaissent au-dessus des activités en direct afin que les événements système rapides semblent toujours importants."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "存続期間の短いオーバーレイはライブ アクティビティの上に表示されるため、迅速なシステム イベントが依然として目立つように感じられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "단기 오버레이가 라이브 활동 위에 표시되므로 빠른 시스템 이벤트가 여전히 눈에 띄게 느껴집니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobreposições de curta duração aparecem acima das atividades ao vivo, de modo que os eventos rápidos do sistema ainda parecem proeminentes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Короткие overlay появляются поверх live activity, чтобы быстрые системные события оставались заметными."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "短暂的覆盖出现在实时活动之上，因此快速的系统事件仍然感觉很突出。"
          }
        }
      }
    },
    "Show a dedicated drop target in the notch while sharing files with AirDrop." : {
