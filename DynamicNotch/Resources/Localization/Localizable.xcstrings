        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenha a atividade ao vivo do ponto de acesso visível até desligá-lo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Держать live activity хот-спота видимой, пока вы ее не выключите."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
