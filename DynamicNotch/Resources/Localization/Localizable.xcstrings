    "Persistent notch content stays visible for as long as the source event is active, then fades away when it ends." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Persistent notch content stays visible for as long as the source event is active, then fades away when it ends."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El contenido de muesca persistente permanece visible mientras el evento de origen esté activo y luego desaparece cuando finaliza."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le contenu persistant reste visible aussi longtemps que l'événement source est actif, puis disparaît à la fin."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "永続的なノッチ コンテンツは、ソース イベントがアクティブである限り表示され続け、終了すると消えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지속적인 노치 콘텐츠는 소스 이벤트가 활성화되어 있는 동안 계속 표시되었다가 종료되면 사라집니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O conteúdo de entalhe persistente permanece visível enquanto o evento de origem estiver ativo e desaparece quando termina."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Постоянный контент выреза остается видимым, пока активно исходное событие, а затем исчезает после его завершения."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只要源事件处于活动状态，持久凹口内容就会保持可见，然后在事件结束时消失。"
          }
        }
      }
    },
